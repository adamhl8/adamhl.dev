---
import type { MarkdownHeading } from "astro"

import Link from "#/components/Link.astro"

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

const indentClass: Record<number, string> = {
  1: "ml-0",
  2: "ml-0",
  3: "ml-4",
  4: "ml-8",
  5: "ml-12",
  6: "ml-16",
}
---

<nav class="sticky top-24">
  <Link href="#title" title="Back to top" titleClass="opacity-50" class="flex flex-col items-start">
    <span class="text-xl font-semibold" slot="before">Table of Contents</span>
  </Link>

  <ol class="mt-4 ml-0 space-y-2">
    {headings.map((heading) => (
        <li
          class:list={[indentClass[heading.depth], "border-l-2 border-base-300 pl-4 transition-colors"]}
          data-heading-id={heading.slug}
        >
          <Link href={`#${heading.slug}`} title={heading.text} />
        </li>
      ))}
  </ol>
</nav>

<script>
// Group the article's children into (nested) sections by heading depth: each element belongs
// to every heading currently open above it, so a parent stays lit while a subsection is on screen.
const article = document.querySelector("article.prose")
const articleElements = article ? [...article.children] : []
const idsByElement = new Map<Element, string[]>()
const openHeadings: { id: string; depth: number }[] = []
const tagRegex = /^H(?<depth>[1-6])$/v

for (const element of articleElements) {
  const match = tagRegex.exec(element.tagName)
  const depth = match?.groups?.["depth"]
  const depthNum = depth && Number(depth)

  if (depthNum) {
    while (openHeadings.length > 0 && (openHeadings.at(-1)?.depth ?? 0) >= depthNum) openHeadings.pop()
    const id = element.getAttribute("id")
    if (id) openHeadings.push({ id, depth: depthNum })
  }

  if (openHeadings.length > 0) idsByElement.set(element, openHeadings.map((item) => item.id))
}

const visibleElements = new Set<Element>()

const observer = new IntersectionObserver((entries) => {
  const changedIds = new Set<string>()
  for (const entry of entries) {
    if (entry.isIntersecting) visibleElements.add(entry.target)
    else visibleElements.delete(entry.target)
    for (const id of idsByElement.get(entry.target) ?? []) changedIds.add(id)
  }
  for (const id of changedIds) {
    const isLit = [...visibleElements].some((element) => idsByElement.get(element)?.includes(id))
    const tocItem = document.querySelector(`nav li[data-heading-id="${id}"]`)
    tocItem?.classList.toggle("border-secondary", isLit)
    tocItem?.classList.toggle("border-base-300", !isLit)
  }
})

for (const element of idsByElement.keys()) observer.observe(element)
</script>
