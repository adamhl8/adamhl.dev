---
import type { CollectionEntry, RenderResult } from "astro:content"
import { type } from "arktype"

import PageTitle from "#components/PageTitle.astro"
import Prose from "#components/Prose.astro"
import TableOfContents from "#layouts/Post/components/TableOfContents.astro"
import { ThemedGiscus } from "#layouts/Post/components/ThemedGiscus.tsx"
import Base from "#layouts/Base/Base.astro"

type BlogProps = CollectionEntry<"blog">
type TILProps = CollectionEntry<"til">
type ShareProps = CollectionEntry<"share">
type Props = (BlogProps | TILProps | ShareProps) & {
  renderedPost: RenderResult
}

const { data, renderedPost } = Astro.props
const { title, date, description = "" } = data
const { Content, headings, remarkPluginFrontmatter } = renderedPost
const readingTime = type("string | undefined").assert(remarkPluginFrontmatter["readingTime"])
---

<Base title={title} description={description}>
  <PageTitle title={title} date={date} description={description} readingTime={readingTime} isPostTitle />

  <Prose> <Content /> </Prose>

  {headings.length > 0 && <TableOfContents headings={headings} slot="toc" />}

  <ThemedGiscus client:only slot="comments" />
</Base>
