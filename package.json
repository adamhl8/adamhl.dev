{
  "name": "astrofy",
  "version": "3.0.0",
  "type": "module",
  "description": "Astrofy is a free and open-source template for your Personal Portfolio Website built with Astro and TailwindCSS. Create in minutes a website with Blog, CV, Project Section, Store and RSS Feed.",
  "private": true,
  "scripts": {
    "build": "bun lint && astro build",
    "dev": "astro dev",
    "lint": "prettier --write **/*.astro && biome check && astro check",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "dependencies": {
    "@astrojs/check": "^0.8.2",
    "@astrojs/mdx": "^3.1.2",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^4.11.5",
    "daisyui": "^4.12.10",
    "dayjs": "^1.11.11",
    "tailwindcss": "^3.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@tailwindcss/typography": "^0.5.13",
    "prettier": "^3.3.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.5.3"
  },
  "trustedDependencies": ["@biomejs/biome", "esbuild", "sharp"]
}
