{
  "name": "adamhl.dev",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "bundle": "rm -rf dist .astro && bun lint && bun bundle:prod",
    "bundle:prod": "bun generate:resume && bun ./scripts/process-favicon.ts && astro build",
    "dev": "astro dev",
    "generate:resume": "resumed render ./src/pages/_resume/resume.json -t jsonresume-theme-react-tailwind -o ./src/pages/resume.html && biome format --write ./src/pages/resume.html",
    "lint": "astro check && markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && ts-path-alias-fix -w -f 'astro.config.ts' && tsc --noEmit && biome check --write && adamhl8-knip",
    "obsidian-share": "./scripts/obsidian-share.ts",
    "prepare": "find .githooks -type f -exec ln -srf {} .git/hooks/ \\; || true",
    "preview": "astro preview",
    "upgrade": "bunx @astrojs/upgrade",
    "start:prod": "bun ./dist/server/entry.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "^5.0.4",
    "astro": "^6.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0"
  },
  "devDependencies": {
    "@adamhl8/configs": "^0.19.2",
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@biomejs/biome": "^2.4.13",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@giscus/react": "^3.1.0",
    "@hbsnow/rehype-sectionize": "^1.0.7",
    "@iconify-json/tabler": "^1.2.33",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro-expressive-code": "^0.41.7",
    "daisyui": "^5.5.19",
    "jsonresume-theme-react-tailwind": "^1.3.0",
    "knip": "^6.7.0",
    "markdown-toc": "^1.2.0",
    "marked": "^18.0.2",
    "mdast-util-to-string": "^4.0.0",
    "reading-time": "^1.5.0",
    "remark-breaks": "^4.0.0",
    "resumed": "^6.1.0",
    "tailwindcss": "^4.2.4",
    "ts-path-alias-fix": "^0.1.3",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "valibot": "^1.3.1",
    "yaml": "^2.8.3"
  }
}
